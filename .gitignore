# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output/

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt/

# Bower dependency directory (https://bower.io/)
bower_components/

# node-waf configuration
.lock-wscript/

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release/

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# next.js build output
.next/

# Docusaurus cache and generated files
.docusaurus/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# yarn v2
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# OS X temporary files
.DS_Store

# IntelliJ IDEA project files; if you want to commit IntelliJ settings, this recipe may be helpful:
# https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
.idea/
*.iml

# Visual Studio Code
.vscode/
!.vscode/tasks.json
!.vscode/launch.json

# Rush temporary files
common/deploy/
common/temp/
common/autoinstallers/*/.npmrc
**/.rush/temp/
*.lock

# Per-agent git worktrees — see scripts/worktree.mjs, .ai/rules/process/workspace.md § Multi-agent worktrees
.worktrees/

# Common toolchain intermediate files
temp/
dist/
dist-storybook/
*.tsbuildinfo

# Heft temporary files
.cache/
.heft/

# Vitepress
docs/.vitepress/cache/
docs/.vitepress/.temp/

# AI workflow run artifacts — ephemeral scratch state, see .ai/workflows/runs/AGENTS.md
.ai/workflows/runs/*
.ai/mcp/mcp.json
!.ai/workflows/runs/AGENTS.md
# (Uses `/*` + `!`, not a bare directory match — git can't re-include a path whose
# parent directory itself was excluded, so a bare `.ai/workflows/runs/` would silently
# defeat this negation.)

# Junie — local tool config
.junie

# Devin — local tool config, generated by `pnpm gen:workflow-docs` (see .ai/workflows/manifest.json)
.devin/

# Claude — local tool config, generated by `pnpm gen:workflow-docs` (see .ai/workflows/manifest.json)
.claude/

# Agent skill files
.agents
/skills-lock.json

# Codex generated bundled data
packages/codex/data/

# REPL example validation temp files
scripts/.repl-tmp/

# REPL library/type/dependency registry — generated by `pnpm gen:repl-registry` from each
# package's build output (see scripts/generate-repl-registry.ts)
docs/.vitepress/theme/components/repl/registry.generated.ts
/packages/refine/test-results/
