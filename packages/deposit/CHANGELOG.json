    {
      "version": "3.0.0",
      "tag": "@vielzeug/deposit_v3.0.0",
      "date": "Sun, 17 May 2026 05:10:17 GMT",
      "comments": {
        "major": [
          {
            "comment": "Release a new major version with a redesigned storage API, normalized persistence behavior, and breaking interface updates across IndexedDB and LocalStorage integration.",
            "author": "Helmuth Saatkamp <helmuthdu@gmail.com>",
