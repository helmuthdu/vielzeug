{
  "name": "@vielzeug/codex",
  "version": "1.0.2",
  "type": "module",
  "description": "MCP server that exposes the vielzeug ecosystem to AI assistants — run locally over stdio or remotely over HTTP",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "codex": "./dist/cli.js"
  },
  "files": [
    "data",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --experimental-strip-types ./scripts/dev.ts",
    "fix": "eslint --fix src",
    "gen:tool-docs": "node --experimental-strip-types ./scripts/generate-tool-docs.ts",
    "lint": "eslint src",
    "postbuild": "pnpm run gen:tool-docs",
    "prepare:data": "node --experimental-strip-types ./scripts/generate-bundled-data.ts",
    "prebuild": "pnpm run prepare:data",
    "prepublishOnly": "pnpm run build",
    "pretest": "pnpm run prepare:data",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:integration": "vitest run --project integration",
    "test:unit": "vitest run --project unit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
