{
  "name": "@vielzeug/buildit",
  "version": "1.0.0",
  "type": "module",
  "customElements": "dist/custom-elements.json",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/types.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/styles.css",
    "./styles/animation.css": "./src/styles/animation.css",
    "./styles/layers.css": "./src/styles/layers.css",
    "./styles/styles.css": "./src/styles/styles.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./accordion": {
      "types": "./dist/accordion.d.ts",
      "import": "./dist/accordion.js",
      "require": "./dist/accordion.cjs"
    },
    "./accordion-item": {
      "types": "./dist/accordion-item.d.ts",
      "import": "./dist/accordion-item.js",
      "require": "./dist/accordion-item.cjs"
    },
    "./alert": {
      "types": "./dist/alert.d.ts",
      "import": "./dist/alert.js",
      "require": "./dist/alert.cjs"
    },
    "./badge": {
      "types": "./dist/badge.d.ts",
      "import": "./dist/badge.js",
      "require": "./dist/badge.cjs"
    },
    "./breadcrumb": {
      "types": "./dist/breadcrumb.d.ts",
      "import": "./dist/breadcrumb.js",
      "require": "./dist/breadcrumb.cjs"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js",
      "require": "./dist/button.cjs"
    },
    "./button-group": {
      "types": "./dist/button-group.d.ts",
      "import": "./dist/button-group.js",
      "require": "./dist/button-group.cjs"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "import": "./dist/card.js",
      "require": "./dist/card.cjs"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.ts",
      "import": "./dist/checkbox.js",
      "require": "./dist/checkbox.cjs"
    },
    "./checkbox-group": {
      "types": "./dist/checkbox-group.d.ts",
      "import": "./dist/checkbox-group.js",
      "require": "./dist/checkbox-group.cjs"
    },
    "./chip": {
      "types": "./dist/chip.d.ts",
      "import": "./dist/chip.js",
      "require": "./dist/chip.cjs"
    },
    "./combobox": {
      "types": "./dist/combobox.d.ts",
      "import": "./dist/combobox.js",
      "require": "./dist/combobox.cjs"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js",
      "require": "./dist/dialog.cjs"
    },
    "./file-input": {
      "types": "./dist/file-input.d.ts",
      "import": "./dist/file-input.js",
      "require": "./dist/file-input.cjs"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js",
      "require": "./dist/form.cjs"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js",
      "require": "./dist/input.cjs"
    },
    "./menu": {
      "types": "./dist/menu.d.ts",
      "import": "./dist/menu.js",
      "require": "./dist/menu.cjs"
    },
    "./progress": {
      "types": "./dist/progress.d.ts",
      "import": "./dist/progress.js",
      "require": "./dist/progress.cjs"
    },
    "./radio": {
      "types": "./dist/radio.d.ts",
      "import": "./dist/radio.js",
      "require": "./dist/radio.cjs"
    },
    "./radio-group": {
      "types": "./dist/radio-group.d.ts",
      "import": "./dist/radio-group.js",
      "require": "./dist/radio-group.cjs"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js",
      "require": "./dist/select.cjs"
    },
    "./skeleton": {
      "types": "./dist/skeleton.d.ts",
      "import": "./dist/skeleton.js",
      "require": "./dist/skeleton.cjs"
    },
    "./slider": {
      "types": "./dist/slider.d.ts",
      "import": "./dist/slider.js",
      "require": "./dist/slider.cjs"
    },
    "./switch": {
      "types": "./dist/switch.d.ts",
      "import": "./dist/switch.js",
      "require": "./dist/switch.cjs"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "import": "./dist/text.js",
      "require": "./dist/text.cjs"
    },
    "./textarea": {
      "types": "./dist/textarea.d.ts",
      "import": "./dist/textarea.js",
      "require": "./dist/textarea.cjs"
    },
    "./toast": {
      "types": "./dist/toast.d.ts",
      "import": "./dist/toast.js",
      "require": "./dist/toast.cjs"
    },
    "./tooltip": {
      "types": "./dist/tooltip.d.ts",
      "import": "./dist/tooltip.js",
      "require": "./dist/tooltip.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp -r src/styles/*.css dist/styles && pnpm run analyze",
    "analyze": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@vielzeug/craftit": "workspace:*",
    "@vielzeug/dragit": "workspace:*",
    "@vielzeug/floatit": "workspace:*",
    "@vielzeug/toolkit": "workspace:*",
    "@vielzeug/virtualit": "workspace:*"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "axe-core": "^4.11.1",
    "browserslist": "^4.28.1",
    "lightningcss": "^1.31.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
