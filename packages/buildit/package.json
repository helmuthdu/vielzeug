  "scripts": {
    "analyze": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "build": "pnpm run sync:exports && pnpm run check:manifest && vite build && pnpm run build:core && cp -r src/styles/*.css dist/styles && pnpm run build:types && pnpm run analyze",
    "build:core": "vite build --config vite.bundle.config.ts",
    "build:types": "tsc -p tsconfig.declarations.json",
    "check:manifest": "node ./check-component-manifest.mjs",
    "dev": "vite",
    "preview": "vite preview",
    "sync:exports": "node ./sync-package-exports.mjs",
    "test": "vitest"
  },
  "dependencies": {
