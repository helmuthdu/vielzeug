{
  "name": "@vielzeug/tempo",
  "version": "1.0.3",
  "description": "Date and time utilities — timezone conversion, DST-safe arithmetic, and Intl formatting",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview",
    "test": "vitest",
    "build:bundle": "vite build --config vite.bundle.config.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  }
}
