{
  "name": "@vielzeug/coins",
  "version": "1.0.1",
  "description": "Bigint-based monetary arithmetic with currency formatting, exchange rates, and rounding policies",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "build:bundle": "vite build --config vite.bundle.config.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
