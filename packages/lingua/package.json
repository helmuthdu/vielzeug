{
  "name": "@vielzeug/lingua",
  "version": "1.0.1",
  "description": "Internationalization with typed translations, pluralization, namespace lazy-loading, and SSR fork support",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./format": {
      "source": "./src/format.ts",
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js",
      "require": "./dist/format.cjs"
    },
    "./validate": {
      "source": "./src/validate.ts",
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js",
      "require": "./dist/validate.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types && pnpm run verify:exports",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview",
    "test": "vitest",
    "build:bundle": "vite build --config vite.bundle.config.ts",
    "verify:exports": "node ./scripts/verify-exports.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
