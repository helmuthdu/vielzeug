{
  "name": "@vielzeug/orbit",
  "version": "1.0.3",
  "description": "Floating element positioning — tooltip, dropdown, popover, and menu placement with middleware",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./devtools": {
      "source": "./src/devtools.ts",
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    },
    "./presets": {
      "source": "./src/presets.ts",
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.cjs"
    },
    "./reactive": {
      "source": "./src/reactive.ts",
      "types": "./dist/reactive.d.ts",
      "import": "./dist/reactive.js",
      "require": "./dist/reactive.cjs"
    },
    "./ssr": {
      "source": "./src/ssr.ts",
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js",
      "require": "./dist/ssr.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "build:bundle": "vite build --config vite.bundle.config.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vielzeug/arsenal": "workspace:*",
    "@vielzeug/ripple": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
