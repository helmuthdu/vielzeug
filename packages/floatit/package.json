{
  "name": "@vielzeug/floatit",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc && vite build  && tsc -p tsconfig.declarations.json",
    "fix": "biome check --write --unsafe src",
    "lint": "biome check src",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
