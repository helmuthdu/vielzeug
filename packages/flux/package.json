{
  "name": "@vielzeug/flux",
  "version": "0.0.1",
  "description": "Composable stream primitive with hot/cold semantics, backpressure, and ecosystem adapters",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:bundle": "vite build --config vite.bundle.config.ts",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@vielzeug/ripple": "workspace:*"
  },
  "peerDependencies": {
    "@vielzeug/courier": "workspace:*",
    "@vielzeug/herald": "workspace:*",
    "@vielzeug/pulse": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@vielzeug/courier": {
      "optional": true
    },
    "@vielzeug/herald": {
      "optional": true
    },
    "@vielzeug/pulse": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vielzeug/courier": "workspace:*",
    "@vielzeug/herald": "workspace:*",
    "@vielzeug/pulse": "workspace:*",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
