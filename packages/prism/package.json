{
  "name": "@vielzeug/prism",
  "version": "1.1.1",
  "description": "Reactive SVG charts — line, bar, area, pie, and sparkline with signal-driven updates",
  "keywords": [
    "chart",
    "svg",
    "visualization",
    "reactive",
    "line-chart",
    "bar-chart",
    "area-chart",
    "typescript"
  ],
  "homepage": "https://vielzeug.dev/prism/",
  "repository": {
    "type": "git",
    "url": "https://github.com/helmuthdu/vielzeug",
    "directory": "packages/prism"
  },
  "bugs": {
    "url": "https://github.com/helmuthdu/vielzeug/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme": {
      "source": "./src/theme/prism.css",
      "import": "./dist/theme/prism.css",
      "default": "./dist/theme/prism.css"
    },
    "./devtools": {
      "source": "./src/devtools/index.ts",
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && mkdir -p dist/theme && cp src/theme/prism.css dist/theme/prism.css && pnpm run build:types",
    "build:bundle": "vite build --config vite.bundle.config.ts",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest"
  },
  "sideEffects": [
    "./dist/theme/**"
  ],
  "dependencies": {
    "@vielzeug/orbit": "workspace:*",
    "@vielzeug/ripple": "workspace:*"
  },
  "devDependencies": {
    "axe-core": "^4.12.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
