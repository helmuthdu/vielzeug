      "comments": {
        "major": [
          {
            "comment": "Major release: full signals-based web component framework built on @vielzeug/stateit; reactive html and css tagged templates with conditional rendering (html.when, html.each, html.show, html.match); component lifecycle hooks (onMount, onUnmount, onUpdated, onCleanup); prop/defineProps for reflected DOM attributes; context API (provide/inject/createContext); form-associated custom elements with ElementInternals; delegated event handling via handle(); shadow DOM refs and refs() helpers; defineEmits and defineSlots for typed component contracts",
            "author": "Helmuth Saatkamp <helmuthdu@gmail.com>",
            "commit": "3ce2565c4a8c872f2540fb4122c5290f83ab3185"
