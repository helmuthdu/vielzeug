{
  "name": "@vielzeug/craftit",
  "version": "1.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./labs": {
      "source": "./src/labs/index.ts",
      "types": "./dist/labs/index.d.ts",
      "import": "./dist/labs.js",
      "require": "./dist/labs.cjs"
    },
    "./directives": {
      "source": "./src/directives/index.ts",
      "types": "./dist/directives/index.d.ts",
      "import": "./dist/directives/index.js",
      "require": "./dist/directives/index.cjs"
    },
    "./test": {
      "source": "./src/test/index.ts",
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test.js",
      "require": "./dist/test.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:bundle": "vite build --config vite.bundle.config.ts",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@vielzeug/floatit": "workspace:*",
    "@vielzeug/stateit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "jsdom": "^29.0.0",
    "terser": "^5.46.1",
    "typescript": "~5.8.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
