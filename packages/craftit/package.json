{
  "name": "@vielzeug/craftit",
  "version": "2.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./controls": {
      "source": "./src/controls/index.ts",
      "types": "./dist/controls/index.d.ts",
      "import": "./dist/controls.js",
      "require": "./dist/controls.cjs"
    },
    "./observers": {
      "source": "./src/observers/index.ts",
      "types": "./dist/observers/index.d.ts",
      "import": "./dist/observers.js",
      "require": "./dist/observers.cjs"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "scripts": {
    "build": "vite build && pnpm run build:bundle && pnpm run build:types",
    "build:bundle": "vite build --config vite.bundle.config.ts",
    "build:types": "tsc -p tsconfig.declarations.json",
    "fix": "eslint --fix src",
    "lint": "eslint src",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@vielzeug/floatit": "workspace:*",
    "@vielzeug/stateit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
