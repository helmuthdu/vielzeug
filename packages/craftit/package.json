{
  "name": "@vielzeug/craftit",
  "version": "1.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./reactivity": {
      "types": "./dist/core/signal.d.ts",
      "import": "./dist/core/signal.js",
      "require": "./dist/core/signal.cjs"
    },
    "./template": {
      "types": "./dist/template/index.d.ts",
      "import": "./dist/template/index.js",
      "require": "./dist/template/index.cjs"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js",
      "require": "./dist/composables/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./dev": {
      "types": "./dist/dev/debug.d.ts",
      "import": "./dist/dev/debug.js",
      "require": "./dist/dev/debug.cjs"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "fix": "biome check --write --unsafe src",
    "lint": "biome check src",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
