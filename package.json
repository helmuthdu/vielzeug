{
  "name": "vielzeug",
  "version": "0.0.1",
  "type": "module",
  "root": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "setup": "rush install",
    "prepare": "lefthook install",
    "build": "rush build",
    "fix": "concurrently -c \"auto\" \"pnpm:fix:js\" \"pnpm:fix:css\"",
    "fix:css": "prettier \"packages/**/*.css\" --write & stylelint --fix \"strict\" packages/**/*.css",
    "fix:js": "eslint --fix",
    "lint": "concurrently -c \"auto\" \"pnpm:lint:js\" \"pnpm:lint:css\"",
    "lint:css": "stylelint packages/**/*.css",
    "lint:js": "eslint",
    "test": "vitest",
    "validate:repl": "node --import jiti/register scripts/validate-repl.ts",
    "gen:repl-registry": "node --import jiti/register scripts/generate-repl-registry.ts",
    "docs:dev": "pnpm gen:repl-registry && vitepress dev docs",
    "docs:dev:refine": "concurrently --no-kill-others -c \"auto\" \"pnpm --filter @vielzeug/refine build:bundle:watch\" \"pnpm docs:dev\"",
    "docs:build": "pnpm gen:repl-registry && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "gen:workflow-docs": "node scripts/sync-workflow-docs.mjs",
    "check:workflow-docs": "node scripts/sync-workflow-docs.mjs --check",
    "worktree:add": "node scripts/worktree.mjs add",
    "worktree:list": "node scripts/worktree.mjs list",
    "worktree:remove": "node scripts/worktree.mjs remove"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "browserslist": "^4.28.2",
    "concurrently": "^10.0.3",
    "eslint": "~10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "lightningcss": "^1.32.0",
    "monaco-editor": "0.55.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.8"
  }
}
