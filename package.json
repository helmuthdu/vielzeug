{
  "name": "vielzeug",
  "version": "0.0.0",
  "type": "module",
  "root": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "setup": "rush install",
    "build": "rush build",
    "fix": "concurrently -c \"auto\" \"pnpm:fix:js\" \"pnpm:fix:css\"",
    "fix:css": "prettier \"packages/**/*.css\" --write & stylelint --fix \"strict\" packages/**/*.css",
    "fix:js": "eslint --fix",
    "lint": "concurrently -c \"auto\" \"pnpm:lint:js\" \"pnpm:lint:css\"",
    "lint:css": "stylelint packages/**/*.css",
    "lint:js": "eslint",
    "test": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "browserslist": "^4.28.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-use-logical-spec": "^5.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.5"
  }
}
