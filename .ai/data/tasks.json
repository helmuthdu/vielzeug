{
  "$schemaVersion": 1,
  "tasks": [
    {
      "key": "analyze",
      "description": "Review or redesign a package or subsystem and produce a concrete plan.",
      "inputs": ["scope", "goal"],
      "references": [".ai/core/policy.md", ".ai/core/workspace.md", ".ai/core/conventions.md", ".ai/tasks/analyze.md"]
    },
    {
      "key": "change",
