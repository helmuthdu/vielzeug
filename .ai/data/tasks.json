      "references": [
        ".ai/core/policy.md",
        ".ai/core/workspace.md",
        ".ai/reference/docs-template.md",
        ".ai/tasks/docs.md"
      ]
    },
    {
      "key": "repl",
      "description": "Update REPL examples to match the current API and recommended usage.",
