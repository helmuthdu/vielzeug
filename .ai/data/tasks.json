      "references": [
        ".ai/core/policy.md",
        ".ai/core/workspace.md",
        ".ai/reference/security-checklist.md",
        ".ai/tasks/validate.md"
      ]
    },
    {
      "key": "docs",
      "description": "Sync package documentation with source and template rules.",
